{
  "version": "1.0.0",
  "skill": "status",
  "description": "Show current task state, lifecycle stage, audit results, and open gaps.",
  "input_schema": {
    "manifest.json": {
      "type": "object",
      "required": true,
      "source": ".dynos/task-{id}/manifest.json (most recent active task)",
      "required_fields": ["task_id", "stage"],
      "field_types": {
        "task_id": "str",
        "stage": "str",
        "classification": "object"
      }
    },
    "spec.md": {
      "type": "string",
      "required": false,
      "source": ".dynos/task-{id}/spec.md"
    },
    "execution-graph.json": {
      "type": "object",
      "required": false,
      "source": ".dynos/task-{id}/execution-graph.json",
      "required_fields": ["task_id", "segments"],
      "field_types": {
        "task_id": "str",
        "segments": "list"
      }
    },
    "audit-reports": {
      "type": "array",
      "required": false,
      "source": ".dynos/task-{id}/audit-reports/*.json"
    },
    "repair-log.json": {
      "type": "object",
      "required": false,
      "source": ".dynos/task-{id}/repair-log.json",
      "required_fields": ["repair_cycle"],
      "field_types": {
        "repair_cycle": "int",
        "batches": "list"
      }
    },
    "test-results.json": {
      "type": "object",
      "required": false,
      "source": ".dynos/task-{id}/test-results.json",
      "required_fields": ["run_at", "passed"],
      "field_types": {
        "run_at": "str",
        "passed": "bool"
      }
    },
    "execution-log.md": {
      "type": "string",
      "required": false,
      "source": ".dynos/task-{id}/execution-log.md"
    }
  },
  "output_schema": {
    "status_report": {
      "type": "string",
      "description": "Human-readable status report with task ID, title, stage, lifecycle progress, execution progress, acceptance criteria coverage, audit results, open findings, test results, repair cycle, and next command"
    }
  }
}
