{
  "version": "1.0.0",
  "skill": "execute",
  "description": "Snapshot, run all executor segments in dependency order, then run the test suite.",
  "input_schema": {
    "manifest.json": {
      "type": "object",
      "required": true,
      "source": ".dynos/task-{id}/manifest.json",
      "required_fields": ["task_id", "stage", "classification"],
      "field_types": {
        "task_id": "str",
        "stage": "str",
        "classification": "object"
      }
    },
    "spec.md": {
      "type": "string",
      "required": true,
      "source": ".dynos/task-{id}/spec.md"
    },
    "plan.md": {
      "type": "string",
      "required": true,
      "source": ".dynos/task-{id}/plan.md"
    },
    "execution-graph.json": {
      "type": "object",
      "required": true,
      "source": ".dynos/task-{id}/execution-graph.json",
      "required_fields": ["task_id", "segments"],
      "field_types": {
        "task_id": "str",
        "segments": "list"
      }
    },
    "dynos_patterns.md": {
      "type": "string",
      "required": false,
      "source": "~/.claude/projects/<project>/memory/dynos_patterns.md"
    }
  },
  "output_schema": {
    "evidence/{segment-id}.md": {
      "type": "string",
      "description": "Evidence file per executor segment documenting files modified, integration points, and acceptance criteria satisfied"
    },
    "snapshot": {
      "type": "object",
      "description": "Git snapshot metadata in manifest.json: branch name, stash_ref, head_sha",
      "required_fields": ["head_sha", "branch"],
      "field_types": {
        "head_sha": "str",
        "branch": "str"
      }
    },
    "test-results.json": {
      "type": "object",
      "optional": true,
      "description": "Test execution results (written only on test failure)",
      "required_fields": ["run_at", "passed"],
      "field_types": {
        "run_at": "str",
        "passed": "bool"
      }
    },
    "execution-log.md": {
      "type": "string",
      "description": "Appended log entries for PRE_EXECUTION_SNAPSHOT, EXECUTION, TEST_EXECUTION stages"
    },
    "handoff-execute-audit.json": {
      "type": "object",
      "description": "Handoff record confirming execute outputs are valid for audit consumption",
      "required_fields": ["from_skill", "to_skill", "handoff_at"],
      "field_types": {
        "from_skill": "str",
        "to_skill": "str",
        "handoff_at": "str",
        "manifest_stage": "str"
      }
    }
  }
}
