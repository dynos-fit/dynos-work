{
  "version": "1.0.0",
  "skill": "dashboard",
  "description": "Display a terminal report summarizing learned policies, finding trends, and executor reliability from task retrospectives.",
  "input_schema": {
    "dynos_patterns.md": {
      "type": "string",
      "required": true,
      "source": "~/.claude/projects/<project>/memory/dynos_patterns.md"
    },
    "task-retrospective.json": {
      "type": "object",
      "required": false,
      "source": "glob .dynos/task-*/task-retrospective.json",
      "required_fields": ["task_id", "quality_score"],
      "field_types": {
        "task_id": "str",
        "quality_score": "number",
        "findings_by_auditor": "object",
        "executor_repair_frequency": "object"
      }
    }
  },
  "output_schema": {
    "terminal_report": {
      "type": "string",
      "description": "Terminal report with policy summary, finding trends, executor reliability scores, and repair cycle statistics"
    }
  }
}
