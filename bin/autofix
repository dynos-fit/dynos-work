#!/usr/bin/env bash
# Standalone CLI for the autofix scanner.
#
# Usage:
#   autofix scan [--root /path]     # run proactive scan
#   autofix list [--root /path]     # list current findings
#   autofix clear [--root /path]    # clear findings
#   autofix policy [--root /path]   # show autofix policy
#   autofix sync-outcomes           # refresh PR/issue outcomes
#   autofix benchmark               # build benchmark summary
#   autofix suppress add|list|remove

set -euo pipefail
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

exec python3 -m autofix "$@"
