#!/usr/bin/env bash
# Unified CLI for dynos-work.
#
# Usage:
#   dynos init                    # set up current project
#   dynos local start             # start project daemon
#   dynos local stop              # stop project daemon
#   dynos local status            # show daemon status
#   dynos dashboard               # start global dashboard server
#   dynos dashboard stop          # stop dashboard server

set -euo pipefail
HOOKS_DIR="$(cd "$(dirname "$0")/../hooks" && pwd)"
MEMORY_DIR="$(cd "$(dirname "$0")/../memory" && pwd)"
REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
# HOOKS_DIR enables legacy `from foo import bar` imports inside hooks/.
# REPO_DIR enables the newer `from hooks.cloud import ...` imports used
# by the cloud module.
export PYTHONPATH="${HOOKS_DIR}:${REPO_DIR}:${PYTHONPATH:-}"

usage() {
  cat <<EOF
dynos — unified CLI for dynos-work

Getting started:
  init          Set up current project (register + start daemon)

Project commands:
  local         Project daemon: start, stop, status, logs, run-once

Global commands:
  dashboard     SPA dashboard: serve (default), stop, restart
  list          List all registered projects
  remove        Unregister a project (default: current dir)
  pause         Pause maintenance for a project
  resume        Resume maintenance for a project
  registry      Project registration: register, unregister, list, pause, resume

Internals (advanced):
  route         Deterministic audit/executor routing
  plan          Planning policy resolution
  patterns      Generate patterns from retrospectives
  ctl           Task lifecycle, approvals, validation
  postmortem    Postmortems and improvements
  calibration   Agent calibration (generate, benchmark, promote/demote)
  memory        Memory aggregation (patterns, trajectories)
  trajectory    Trajectory store operations
  bench         Benchmark runner
  report        Generate reports

Run 'dynos <subcommand> --help' for details.
EOF
}

if [ $# -eq 0 ]; then
  usage
  exit 0
fi

cmd="$1"; shift

case "$cmd" in
  # --- Getting started ---
  init)
    root="$(pwd)"
    if [ ! -d "$root/.git" ]; then
      echo "Error: not a git repository" >&2
      exit 1
    fi
    echo "Registering project..."
    python3 "${HOOKS_DIR}/registry.py" register "$root" 2>/dev/null || true
    mkdir -p "$root/.dynos"
    if python3 -c "
import sys
sys.path.insert(0, '${HOOKS_DIR}')
from daemon import current_pid
from pathlib import Path
pid = current_pid(Path('$root'))
sys.exit(0 if pid else 1)
" 2>/dev/null; then
      echo "Daemon already running. Use 'dynos local stop' to stop it first."
      exit 0
    fi
    echo "Starting local daemon..."
    python3 "${HOOKS_DIR}/daemon.py" start --root "$root" 2>/dev/null || true
    echo ""
    echo "Project ready: $root"
    echo "Daemon running"
    echo ""
    echo "Next: use /dynos-work:start in Claude Code to begin a task"
    ;;

  # --- Project commands ---
  local)
    exec python3 "${HOOKS_DIR}/daemon.py" "$@"
    ;;
  daemon|maintain) exec python3 "${HOOKS_DIR}/daemon.py" "$@" ;;

  # --- Global commands ---
  registry) exec python3 "${HOOKS_DIR}/registry.py" "$@" ;;
  list) exec python3 "${HOOKS_DIR}/registry.py" list "$@" ;;
  remove)
    # dynos remove [--root /path] or dynos remove /path (positional)
    target="$(pwd)"
    for arg in "$@"; do
      case "$arg" in
        --root) shift; target="$1"; shift ;;
        --root=*) target="${arg#--root=}" ;;
        -*) ;;
        *) target="$arg" ;;
      esac
    done
    # Stop daemon first if running
    echo "Stopping daemon for $target..."
    PYTHONPATH="${HOOKS_DIR}:${PYTHONPATH:-}" python3 "${HOOKS_DIR}/daemon.py" stop --root "$target" 2>/dev/null || true
    # Unregister
    exec python3 "${HOOKS_DIR}/registry.py" unregister "$target"
    ;;
  pause)
    target="$(pwd)"
    for arg in "$@"; do
      case "$arg" in
        --root) shift; target="$1"; shift ;;
        --root=*) target="${arg#--root=}" ;;
        -*) ;;
        *) target="$arg" ;;
      esac
    done
    exec python3 "${HOOKS_DIR}/registry.py" pause "$target"
    ;;
  resume)
    target="$(pwd)"
    for arg in "$@"; do
      case "$arg" in
        --root) shift; target="$1"; shift ;;
        --root=*) target="${arg#--root=}" ;;
        -*) ;;
        *) target="$arg" ;;
      esac
    done
    exec python3 "${HOOKS_DIR}/registry.py" resume "$target"
    ;;

  # --- Global dashboard (top-level) ---
  dashboard)
    if [ $# -eq 0 ]; then
      exec python3 "${REPO_DIR}/telemetry/dashboard.py" serve
    fi
    subcmd="$1"; shift
    case "$subcmd" in
      stop|kill) exec python3 "${REPO_DIR}/telemetry/dashboard.py" kill ;;
      restart)   exec python3 "${REPO_DIR}/telemetry/dashboard.py" restart ;;
      *)         exec python3 "${REPO_DIR}/telemetry/dashboard.py" "$subcmd" "$@" ;;
    esac
    ;;

  # --- Internals ---
  route)      exec python3 "${HOOKS_DIR}/router.py" "$@" ;;
  plan)       exec python3 "${HOOKS_DIR}/planner.py" "$@" ;;
  patterns)   exec python3 "${HOOKS_DIR}/patterns.py" "$@" ;;
  ctl)        exec python3 "${HOOKS_DIR}/ctl.py" "$@" ;;
  postmortem) exec python3 "${HOOKS_DIR}/postmortem.py" "$@" ;;
  calibration|evolve) exec python3 "${MEMORY_DIR}/agent_generator.py" "$@" ;;
  worktree)   exec python3 "${HOOKS_DIR}/worktree.py" "$@" ;;
  rules-check)
    # AC 4 (task-007): invoke receipt_rules_check_passed on <task_dir>.
    # Exit 0 on success, 1 on ValueError refusal, 2 on missing arg or internal error.
    if [ $# -lt 1 ]; then
      echo "usage: dynos rules-check <task_dir>" >&2
      exit 2
    fi
    exec python3 -c "
import sys
from pathlib import Path
sys.path.insert(0, '${HOOKS_DIR}')
from lib_receipts import receipt_rules_check_passed
td = Path(sys.argv[1])
if not td.exists() or not td.is_dir():
    print(f'task_dir not found: {td}', file=sys.stderr); sys.exit(2)
try:
    p = receipt_rules_check_passed(td, mode='all')
    print(f'rules-check-passed: {p}'); sys.exit(0)
except ValueError as e:
    print(f'ValueError: {e}', file=sys.stderr); sys.exit(1)
except Exception as e:
    print(f'{type(e).__name__}: {e}', file=sys.stderr); sys.exit(2)
" "$@"
    ;;
  memory)     exec python3 "${HOOKS_DIR}/patterns.py" "$@" ;;
  trajectory) exec python3 "${HOOKS_DIR}/trajectory.py" "$@" ;;
  bench)      exec python3 "${HOOKS_DIR}/bench.py" "$@" ;;
  report)     exec python3 "${HOOKS_DIR}/report.py" "$@" ;;

  # --- Cloud subcommands (enterprise, opt-in) ---
  login|logout|status|config)
    # Forward to hooks.cloud.cli — keep the subcommand name as argv[1].
    exec python3 -m hooks.cloud.cli "$cmd" "$@"
    ;;
  cloud)
    # `dynos cloud <sub>` — explicit namespace if users prefer.
    exec python3 -m hooks.cloud.cli "$@"
    ;;

  help|-h|--help) usage ;;
  *) echo "Unknown subcommand: $cmd" >&2; usage >&2; exit 1 ;;
esac
