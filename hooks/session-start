#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PROJECT_ROOT="$(pwd)"

python3 "${SCRIPT_DIR}/dynoregistry.py" set-active "${PROJECT_ROOT}" >/dev/null 2>&1 || true
python3 "${SCRIPT_DIR}/dynodashboard.py" generate --root "${PROJECT_ROOT}" >/dev/null 2>&1 || true
python3 "${SCRIPT_DIR}/dynomaintain.py" ensure --root "${PROJECT_ROOT}" >/dev/null 2>&1 || true

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

session_context="dynos-work active. Use /dynos-work:start for new tasks. Power-user: /dynos-work:audit, /dynos-work:maintain, /dynos-work:status, /dynos-work:repair, /dynos-work:resume, /dynos-work:investigate. Live dashboard: python3 hooks/dynodashboard.py serve --root ."

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
fi

exit 0
